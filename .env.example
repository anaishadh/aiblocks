# aiblocks environment variables
# Copy this file to .env and fill in your keys
# cp .env.example .env

# Required for OpenAI embeddings and generation (default provider)
OPENAI_API_KEY=your-openai-key-here

# Optional — only needed if using Cohere reranker or embeddings
COHERE_API_KEY=your-cohere-key-here

# Optional — only needed if using Anthropic as generator
ANTHROPIC_API_KEY=your-anthropic-key-here
